{
  "name": "discord-command-bridge-mcp-server",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal Discord command bridge for Antigravity via MCP",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:test": "tsc -p tsconfig.test.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "npm run build:test && node --test dist-test/**/*.test.js",
    "start": "node dist/index.js"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^11.8.1",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.3"
  }
}
